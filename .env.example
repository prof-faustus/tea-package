# Package configuration (copy to .env for local dev; CI/deploy override these).
# The development database is a user-owned PostgreSQL cluster on localhost
# (tools/pg_user_cluster.sh). Deploy/CI pin postgres:16 (section 09 compose).
TEA_DB_DSN=postgresql://tea:tea@127.0.0.1:5455/tea

# Engine bridge. The engine runs in WSL/Linux (the Windows .exe will not execute
# under the harness, V-ENV-0001). TEA_BSV_BIN is the runnable binary path; the
# bridge invokes it (in WSL) with file inputs/outputs on a shared path.
TEA_BSV_BIN=/home/craig/engine/target/release/tea-bsv

# Network selector for engine chain operations (REQ-EVID-0030): REGTEST|TESTNET|MAINNET
TEA_NETWORK=REGTEST
